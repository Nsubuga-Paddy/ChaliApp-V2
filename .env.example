# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_OCR_MODEL=gpt-4o-mini
OPENAI_HTTP_TIMEOUT_SECONDS=120

# Celery (required on Railway for background PDF indexing — deploy worker + Redis)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (comma-separated origins for mobile/web clients)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Pegasus payment gateway ──────────────────────────────────────────────────
# Obtain sandbox credentials from https://www.pegasustechnologies.co.ug/
PEGASUS_BASE_URL=https://sandbox.pegasusgateway.com
PEGASUS_USERNAME=
PEGASUS_PASSWORD=
PEGASUS_VENDOR_CODE=
PEGASUS_TIMEOUT=30

# Pegasus biller codes (leave blank to use the defaults in pegasus_client.py)
PEGASUS_BILLER_YAKA=YAKA
PEGASUS_BILLER_WATER=NWSC
PEGASUS_BILLER_AIRTIME_MTN=MTNAIRTIME
PEGASUS_BILLER_AIRTIME_AIRTEL=AIRTELAIRTIME
PEGASUS_BILLER_TV=DSTV
PEGASUS_BILLER_SCHOOL=SCHOOLFEES
PEGASUS_BILLER_URA=URA
